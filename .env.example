# Copy this file to .env.dev (and/or .env.sandbox) and fill in real values.
# These files are git-ignored. Never commit real config.

# Stack name prefix — all resource names derive from this.
SERVICE_NAME=aws-serverless-template

# Deployment stage (dev, sandbox, prod, ...).
STAGE=dev

# AWS region to deploy into.
AWS_REGION=ap-southeast-2

# Amazon Connect instance ID the hello-world Lambda will DescribeInstance on.
# Leave blank to have the sample skip the Connect call gracefully.
CONNECT_INSTANCE_ID=
