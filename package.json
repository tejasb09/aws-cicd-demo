{
  "name": "nn-aws-cicd-demo",
  "description": "nn-aws-cicd-demo service (bootstrapped from the aws template)",
  "main": "serverless.ts",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "clean": "rm -rf .serverless coverage .esbuild",
    "deploy": "bunx serverless deploy",
    "deploy:dev": "export $(grep -v '^#' .env.dev | xargs) && bunx serverless deploy --stage ${STAGE:-dev} --region ${AWS_REGION:-ap-southeast-2}",
    "deploy:sandbox": "export $(grep -v '^#' .env.sandbox | xargs) && bunx serverless deploy --stage ${STAGE:-sandbox} --region ${AWS_REGION:-ap-southeast-2}",
    "remove:dev": "export $(grep -v '^#' .env.dev | xargs) && bunx serverless remove --stage ${STAGE:-dev} --region ${AWS_REGION:-ap-southeast-2}",
    "offline": "export $(grep -v '^#' .env.dev | xargs) && bunx serverless offline start --stage ${STAGE:-dev} --region ${AWS_REGION:-ap-southeast-2}",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --config .prettierrc 'src/**/*.ts' 'resources/**/*.ts' 'serverless.ts' --write",
    "test": "vitest --run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "validate": "bun run test && bun run lint && bun run type-check",
    "prepare": "husky"
  },
  "author": "Cloudwave Solutions",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-connect": "^3.825.0",
    "@aws-sdk/client-dynamodb": "^3.825.0",
    "@aws-sdk/client-secrets-manager": "^3.825.0",
    "@aws-sdk/lib-dynamodb": "^3.825.0"
  },
  "devDependencies": {
    "@serverless/typescript": "^3.38.0",
    "@types/aws-lambda": "^8.10.136",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.37.0",
    "eslint-config-prettier": "^8.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.1",
    "serverless": "3.40.0",
    "serverless-esbuild": "^1.55.1",
    "serverless-iam-roles-per-function": "^3.2.0",
    "serverless-offline": "^14.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3",
    "vitest": "^3.2.4"
  }
}
